enum Result { Ok(value) Err(msg) }
fun divide(a, b) { if (b == 0) return Err("div/0"); return Ok(a / b); }
var cases = [divide(10, 2), divide(7, 0), divide(9, 3)];
var i = 0;
while (i < 3) {
    var label = match cases[i] { case Ok(v) => "ok" case Err(m) => "err" };
    print label;
    i = i + 1;
}
