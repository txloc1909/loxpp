enum Result { Ok(value) Err(msg) }

fun divide(a, b) {
    if (b == 0) return Err("division by zero");
    return Ok(a / b);
}

var cases = [divide(10, 2), divide(7, 0)];
var i = 0;
while (i < 2) {
    match cases[i] {
        case Ok(v) => print "ok";
        case Err(m) => print "err";
    }
    i = i + 1;
}
