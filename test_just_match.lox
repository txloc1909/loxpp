enum Result { Ok(value) Err(msg) }

fun divide(a, b) {
    if (b == 0) return Err("division by zero");
    return Ok(a / b);
}

var cases = [divide(10, 2), divide(7, 0)];
var i = 0;
while (i < 2) {
    print "Before match:";
    print cases[i];
    print match cases[i] {
        case Ok(v) => "ok"
        case Err(m) => "err"
    };
    i = i + 1;
}
