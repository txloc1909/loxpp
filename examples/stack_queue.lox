// CHECK: === Stack as bracket-matching checker ===
print "=== Stack as bracket-matching checker ===";
fun isBalanced(tokens, n) {
    var stk = Stack();
    var i = 0;
    while (i < n) {
        var t = tokens[i];
        if (t == "(" or t == "[" or t == "{") {
            stk.push(t);
        } else if (t == ")") {
            if (stk.isEmpty() or stk.pop() != "(") return false;
        } else if (t == "]") {
            if (stk.isEmpty() or stk.pop() != "[") return false;
        } else if (t == "}") {
            if (stk.isEmpty() or stk.pop() != "{") return false;
        }
        i = i + 1;
    }
    return stk.isEmpty();
}

var balanced   = ["(", "[", "{", "}", "]", ")"];
var unbalanced = ["(", "[", "}", "]", ")"];
print "balanced:   " + str(isBalanced(balanced, 6));
// CHECK: balanced:   true
print "unbalanced: " + str(isBalanced(unbalanced, 5));
// CHECK: unbalanced: false
