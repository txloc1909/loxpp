// ast_eval.lox — expression AST evaluator using class patterns (visitor pattern).
// Demonstrates: recursive class pattern dispatch as a substitute for virtual dispatch.

class Num { init(v)      { this.v = v; } }
class Add { init(l, r)   { this.l = l; this.r = r; } }
class Sub { init(l, r)   { this.l = l; this.r = r; } }
class Mul { init(l, r)   { this.l = l; this.r = r; } }
class Neg { init(e)      { this.e = e; } }

fun eval(node) {
    return match node {
        case Num{v}    => v
        case Add{l, r} => eval(l) + eval(r)
        case Sub{l, r} => eval(l) - eval(r)
        case Mul{l, r} => eval(l) * eval(r)
        case Neg{e}    => -eval(e)
        case _         => 0
    };
}

fun pretty(node) {
    return match node {
        case Num{v}    => str(v)
        case Add{l, r} => "(" + pretty(l) + " + " + pretty(r) + ")"
        case Sub{l, r} => "(" + pretty(l) + " - " + pretty(r) + ")"
        case Mul{l, r} => "(" + pretty(l) + " * " + pretty(r) + ")"
        case Neg{e}    => "(-" + pretty(e) + ")"
        case _         => "?"
    };
}

// (2 + 3) * -(4)  =>  -20
var expr = Mul(Add(Num(2), Num(3)), Neg(Num(4)));
// CHECK: -20
print eval(expr);
// CHECK: ((2 + 3) * (-4))
print pretty(expr);

// 10 - (3 + 2)  =>  5
var expr2 = Sub(Num(10), Add(Num(3), Num(2)));
// CHECK: 5
print eval(expr2);
// CHECK: (10 - (3 + 2))
print pretty(expr2);
