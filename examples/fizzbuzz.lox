// fizzbuzz.lox — Classic FizzBuzz using the % operator.
//
// Demonstrates: %, if/else chains, loops, str().

print "=== FizzBuzz (1–30) ===";
var i = 1;
while (i <= 30) {
    if (i % 15 == 0) {
        print "FizzBuzz";
    } else if (i % 3 == 0) {
        print "Fizz";
    } else if (i % 5 == 0) {
        print "Buzz";
    } else {
        print str(i);
    }
    i = i + 1;
}
